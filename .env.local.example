# BAAM System G — REA Premium Template
# Copy to .env.local and fill in your values

# Site — set BOTH for maximum compatibility
NEXT_PUBLIC_DEFAULT_SITE=realestate
NEXT_PUBLIC_DEFAULT_SITE_ID=realestate
NEXT_PUBLIC_SITE_URL=http://localhost:3050
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Supabase — REA dedicated project (NEVER reuse Julia Studio's project)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth
JWT_SECRET=change-me-to-a-long-random-string

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com
CONTACT_FALLBACK_TO=agent@yourdomain.com
ALERT_TO=admin@yourdomain.com

# Media providers
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# MLS Grid (OneKey MLS feed)
# Token is issued by MLS Grid after vendor + broker license approval
MLS_GRID_ACCESS_TOKEN=
# MLS system name: 'key2' = OneKey MLS (Long Island / NYC metro)
MLS_GRID_ORIGINATING_SYSTEM_NAME=key2
# Site ID to sync listings into (used by cron job)
MLS_GRID_SITE_ID=
# Override API endpoint (optional, default: https://api.mlsgrid.com/v2/Property)
# MLS_GRID_ENDPOINT=https://api.mlsgrid.com/v2/Property

# Cron job auth (set a random string, pass in Authorization: Bearer header)
CRON_SECRET=
